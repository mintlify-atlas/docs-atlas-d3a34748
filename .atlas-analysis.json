    "~/.config/rofi/scripts/theme-switcher.sh - Theme selector",
    "~/.config/rofi/scripts/wallpaper-switcher.sh - Wallpaper selector",
    "~/.config/rofi/scripts/menu-iconos.sh - Emoji/icon menu",
    "~/.config/scripts/mode-hacker.sh - Hacker layout mode",
    "~/.config/scripts/setwallpaper.sh - Wallpaper setter",
