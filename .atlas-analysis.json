  "keyFeatures": [
    "Hyprland-style keybindings for Sway WM",
    "Six pre-configured themes with consistent styling",
    "Rofi-based app launcher and power menu",
    "Waybar status bar with Sway integration",
    "Automated dotfile installation and synchronization",
    "Custom SDDM astronaut login theme",
    "Theme switcher with live reload support",
    "Wallpaper management system",
    "Multimedia key support (volume, brightness, playback)",
    "Virtual keyboard support for SDDM"
